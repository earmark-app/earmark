# Timezone for cron and log timestamps
TZ=UTC

# Python logging level (debug, info, warning, error)
LOG_LEVEL=info

# Path to SQLite DB and cache files
DATA_DIR=/data

# If set, enables HTTP Basic Auth on the web GUI (username: admin)
GUI_PASSWORD=

# If true, log all changes but don't execute writes
DRY_RUN=false

# Web GUI port
PORT=8787
